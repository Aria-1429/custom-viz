{
  "name": "custom_viz_country_graph",
  "version": "1.0.1",
  "description": "A country ranking bar chart with flags, top-N limiting, sorting, and an editable low/high value color scale",
  "author": "Yuto Ishitsuki",
  "type": "module",
  "scripts": {
    "build": "node build.mjs --entry=visualization.jsx",
    "build:prod": "NODE_ENV=production node build.mjs --entry=visualization.jsx",
    "dev": "node build.mjs --entry=visualization.jsx --watch",
    "package": "node package.mjs",
    "verify": "node test/verify.mjs"
  },
  "devDependencies": {
    "@splunk/dashboard-studio-extension": "^1.0.0",
    "@splunk/react-ui": "^5.9.0",
    "@splunk/themes": "^1.4.0",
    "chalk": "^5.3.0",
    "esbuild": "^0.27.3",
    "happy-dom": "^20.11.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "styled-components": "^5.3.10",
    "tar": "^7.4.3"
  },
  "dependencies": {
    "country-flag-icons": "^1.6.20"
  }
}
